# -----------------------------------------------------------------------------
# secrets.toml.example — copy this to `secrets.toml` and fill in the real values.
#
# This example file is SAFE to commit (it has no real secrets). The real file,
# `.streamlit/secrets.toml`, holds your API key and login credentials and is
# git-ignored so it never lands in GitHub. On Streamlit Community Cloud you paste
# these same values into the app's "Secrets" box instead of using a file.
#
# See docs/DEPLOY_GUIDE.md for the click-by-click walkthrough.
# -----------------------------------------------------------------------------

# --- The API key that writes the AI explanations -----------------------------
# Set ONE of these. It stays server-side and is never shown to users.
# ANTHROPIC_API_KEY = "sk-ant-..."     # Claude
# GEMINI_API_KEY    = "..."            # Gemini (wins if both are set)


# --- Google sign-in (Streamlit's built-in login) -----------------------------
# Present ANY [auth] section => the tool shows a "Sign in with Google" button and
# reserves the paid AI for approved users. Remove the whole [auth] section to run
# fully open (the API key, if set, then drives explanations for everyone).
#
# cookie_secret: any long random string (used to sign the login cookie).
# redirect_uri:  your app's URL + /oauth2callback
#                local:  http://localhost:8501/oauth2callback
#                cloud:  https://YOUR-APP.streamlit.app/oauth2callback
# client_id / client_secret: from a Google OAuth "Web application" credential
#                (Google Cloud Console -> APIs & Services -> Credentials).
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-a-long-random-string"
client_id = "your-google-client-id.apps.googleusercontent.com"
client_secret = "your-google-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"


# --- Who may use the paid AI explanations ------------------------------------
# Signed-in users NOT covered here still get the free offline explanations.
# Leave both lists empty to let ANY signed-in user use the AI (the app warns you).
[access]
emails = ["you@gmail.com"]        # exact addresses you approve
domains = []                       # or approve a whole company domain, e.g. ["acme.com"]
